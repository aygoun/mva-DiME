                <mxCell id="lWQMNzsmkOXiz3vmswGi-775" value="&lt;i&gt;- guitar&amp;nbsp;&lt;/i&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-size: 15px;&quot;&gt;🎸&lt;/span&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
